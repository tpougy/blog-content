#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""new-post — scaffold bilingual blog post stubs."""

from __future__ import annotations

import re
import sys
from dataclasses import dataclass
from datetime import date
from pathlib import Path


@dataclass
class PostPaths:
    slug: str
    prefix: int
    en_dir: Path
    pt_dir: Path


def next_prefix(posts_en: Path) -> int:
    existing = [
        int(m.group(1))
        for d in posts_en.iterdir()
        if d.is_dir() and (m := re.match(r"^(\d+)-", d.name))
    ]
    return max(existing, default=0) + 1


def make_slug(title: str, prefix: int) -> str:
    slug_body = re.sub(r"[^a-z0-9]+", "-", title.lower()).strip("-")
    return f"{prefix:02d}-{slug_body}"


def scaffold(title: str, vault_root: Path) -> None:
    posts_en = vault_root / "posts" / "en"
    posts_pt = vault_root / "posts" / "pt"
    prefix = next_prefix(posts_en)
    slug = make_slug(title, prefix)
    today = date.today().isoformat()

    for lang, base in [("en", posts_en), ("pt", posts_pt)]:
        post_dir = base / slug
        post_dir.mkdir(parents=True, exist_ok=True)
        (post_dir / "assets").mkdir(exist_ok=True)
        (post_dir / "article.md").write_text(
            f'---\ntitle: "{title}"\ndescription: ""\ndate: {today}\nlang: {lang}\ndraft: true\n---\n\n'
        )
        print(f"Created: {post_dir / 'article.md'}")


if __name__ == "__main__":
    if len(sys.argv) < 2:
        print('Usage: ./scripts/new-post "My Article Title"', file=sys.stderr)
        sys.exit(1)
    scaffold(sys.argv[1], Path(__file__).parent.parent)
